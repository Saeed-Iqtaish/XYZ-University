@model XYZ_University.Models.ApplicationUser

@{
    ViewData["Title"] = "Manage Role";
    var allRoles = ViewBag.Roles as List<string>;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">

                <div class="card-header bg-white border-bottom p-4">
                    <h3 class="fw-bold mb-0">Manage User Role</h3>
                    <p class="text-muted small mb-0">Update permissions for @Model.Email</p>
                </div>

                <div class="card-body p-4">
                    <form asp-action="AssignRole" method="post">
                        <input type="hidden" name="userId" value="@Model.Id" />

                        <div asp-validation-summary="All" class="text-danger mb-3 small fw-bold"></div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-uppercase text-muted">User Name</label>
                            <input type="text" class="form-control bg-light" value="@Model.FirstName @Model.LastName" readonly />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-uppercase text-muted">Current Role</label>
                            <div class="p-3 border rounded bg-light text-primary fw-bold">
                                @(ViewBag.CurrentRole ?? "No Role Assigned")
                            </div>
                        </div>

                        <div class="form-group mb-4">
                            <label class="form-label fw-bold small text-uppercase">Assign New Role</label>
                            <select name="role" id="roleSelector" class="form-select form-select-lg" onchange="toggleDepartment()">
                                @foreach (var role in allRoles)
                                {
                                    <option value="@role" selected="@(role == ViewBag.CurrentRole)">@role</option>
                                }
                            </select>
                        </div>

                        <div class="form-group mb-4" id="departmentSection" style="display:none;">
                            <label class="form-label fw-bold small text-uppercase text-primary">Assign Department</label>
                            <div class="alert alert-info py-2 small mb-2">
                                <i class="bi bi-info-circle"></i> Required for Instructors
                            </div>

                            <select name="departmentId" class="form-select" asp-items="ViewBag.DepartmentId">
                                <option value="">-- Select Department --</option>
                            </select>

                            <span class="text-danger fw-bold small">
                                @Html.ValidationMessage("departmentId")
                            </span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary fw-bold py-2">Update Role & Department</button>
                            <a asp-action="Index" class="btn btn-light text-secondary border">Cancel</a>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleDepartment() {
            var role = document.getElementById("roleSelector").value;
            var deptSection = document.getElementById("departmentSection");

            if (role === "Instructor") {
                deptSection.style.display = "block";
            } else {
                deptSection.style.display = "none";
            }
        }

        toggleDepartment();
    </script>
}