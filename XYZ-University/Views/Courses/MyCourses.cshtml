@model IEnumerable<XYZ_University.Models.Course>
@using XYZ_University.Models

@{
    ViewData["Title"] = "My Assigned Courses";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<div class="container py-4">

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">My Class Roster</li>
        </ol>
    </nav>

    <div class="d-flex align-items-center mb-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary me-3 shadow-sm px-3">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
        <h2 class="mb-0 fw-bold">
            <i class="bi bi-person-video3 text-primary me-2"></i> My Assigned Courses
        </h2>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6">
                <div class="card h-100 shadow-sm border-0 hover-card p-3">
                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h5 class="fw-bold text-primary mb-0">
                                    CS@(item.CourseId)0@(item.CourseId)
                                </h5>

                                @if (item is Lab)
                                {
                                    <span class="badge bg-warning text-dark border border-warning mt-1">
                                        <i class="bi bi-pc-display"></i> Lab Session
                                    </span>
                                }
                                else if (item is OnlineCourse)
                                {
                                    <span class="badge bg-info text-dark border border-info mt-1">
                                        <i class="bi bi-wifi"></i> Online
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary mt-1">
                                        <i class="bi bi-book"></i> Lecture
                                    </span>
                                }
                            </div>

                            <span class="badge bg-light text-dark border">
                                @item.Credits Credits
                            </span>
                        </div>

                        <h3 class="card-title fw-bold text-dark mb-3 mt-2">@item.Title</h3>

                        <div class="d-flex align-items-center text-secondary mb-4">
                            <i class="bi bi-people-fill me-2 fs-5"></i>
                            <span class="fw-bold">
                                @(item.Enrollments?.Count ?? 0) Students Enrolled
                            </span>
                        </div>

                        <div class="text-end">
                            <a asp-controller="Enrollments" asp-action="Index" asp-route-courseId="@item.CourseId"
                               class="text-primary text-decoration-none fw-bold">
                                Manage Roster <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="alert alert-info border-0 shadow-sm">
                    <i class="bi bi-info-circle-fill me-2"></i> You have not been assigned to any courses yet.
                </div>
            </div>
        }
    </div>
</div>