@model XYZ_University.Models.Course

@{
    ViewData["Title"] = "Delete Course";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">

                <div class="card-header bg-danger text-white p-4">
                    <h3 class="fw-bold mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i>Delete Course?</h3>
                    <p class="mb-0 text-white-50">This action cannot be undone.</p>
                </div>

                <div class="card-body p-4">
                    <h5 class="text-center mb-4">Are you sure you want to delete <strong class="text-dark">@Model.Title</strong>?</h5>

                    <div class="bg-light p-3 rounded border mb-4">
                        <div class="row mb-2">
                            <div class="col-4 fw-bold text-muted small text-uppercase">Credits</div>
                            <div class="col-8">@Model.Credits</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-4 fw-bold text-muted small text-uppercase">Department</div>
                            <div class="col-8">@(Model.Department?.Name ?? "None")</div>
                        </div>
                        <div class="row">
                            <div class="col-4 fw-bold text-muted small text-uppercase">Instructor</div>
                            <div class="col-8">@(Model.Instructor?.FirstName ?? "Unassigned") @(Model.Instructor?.LastName)</div>
                        </div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="CourseId" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger fw-bold py-2">Confirm Delete</button>
                            <a asp-action="Index" class="btn btn-light text-secondary border">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>