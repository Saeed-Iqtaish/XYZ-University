@model IEnumerable<XYZ_University.Models.Course>
@using XYZ_University.Models

@{
    ViewData["Title"] = "Course Catalog";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<div class="container py-4">

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Course Catalog</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary me-3 shadow-sm">
                <i class="bi bi-arrow-left"></i> Dashboard
            </a>
            <h2 class="mb-0 fw-bold">
                <i class="bi bi-journal-bookmark-fill text-primary me-2"></i> Course Catalog
            </h2>
        </div>

        <a asp-action="Create" class="btn btn-primary shadow-sm fw-bold px-3">
            <i class="bi bi-plus-lg"></i> Create Course
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3">Code</th>
                        <th>Title</th>
                        <th>Type</th>
                        <th>Credits</th>
                        <th>Department</th>
                        <th>Instructor</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-secondary">
                                #@item.CourseId
                            </td>

                            <td class="fw-bold text-dark">
                                @item.Title
                            </td>

                            <td>
                                @if (item is Lab)
                                {
                                    <span class="badge bg-warning text-dark border border-warning">
                                        <i class="bi bi-pc-display me-1"></i> Lab
                                    </span>
                                }
                                else if (item is OnlineCourse)
                                {
                                    <span class="badge bg-info text-dark border border-info">
                                        <i class="bi bi-wifi me-1"></i> Online
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-secondary border">
                                        <i class="bi bi-book me-1"></i> Lecture
                                    </span>
                                }
                            </td>

                            <td>@item.Credits</td>

                            <td>
                                <span class="badge bg-light text-dark border">
                                    @(item.Department?.Name ?? "General")
                                </span>
                            </td>

                            <td>
                                @if (item.Instructor != null)
                                {
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-person-circle text-secondary me-2"></i>
                                        <span>@item.Instructor.FirstName @item.Instructor.LastName</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted small fst-italic">Unassigned</span>
                                }
                            </td>

                            <td class="text-end pe-4">
                                <a asp-action="Delete" asp-route-id="@item.CourseId" class="text-danger me-3" title="Delete">
                                    <i class="bi bi-trash-fill fs-5"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.CourseId" class="text-primary" title="Edit">
                                    <i class="bi bi-pencil-square fs-5"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>