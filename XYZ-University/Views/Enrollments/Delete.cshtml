@model XYZ_University.Models.Enrollment

@{
    ViewData["Title"] = "Drop Student";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">

                <div class="card-header bg-danger text-white p-4">
                    <h3 class="fw-bold mb-0"><i class="bi bi-person-x-fill me-2"></i>Drop Student?</h3>
                    <p class="mb-0 text-white-50">This will remove the student from the class roster.</p>
                </div>

                <div class="card-body p-4">
                    <h5 class="text-center mb-4">Are you sure you want to remove <strong class="text-dark">@Model.Student?.FirstName @Model.Student?.LastName</strong>?</h5>

                    <div class="bg-light p-3 rounded border mb-4">
                        <div class="row mb-2">
                            <div class="col-4 fw-bold text-muted small text-uppercase">Course</div>
                            <div class="col-8">@Model.Course?.Title</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-4 fw-bold text-muted small text-uppercase">Email</div>
                            <div class="col-8">@Model.Student?.Email</div>
                        </div>
                        <div class="row">
                            <div class="col-4 fw-bold text-muted small text-uppercase">Current Grade</div>
                            <div class="col-8 fw-bold">@(Model.Grade ?? "N/A")</div>
                        </div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" name="courseId" value="@Model.CourseId" />
                        <input type="hidden" name="studentId" value="@Model.StudentId" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger fw-bold py-2">Confirm Drop</button>
                            <a asp-action="Index" asp-route-courseId="@Model.CourseId" class="btn btn-light text-secondary border">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>