@model IEnumerable<XYZ_University.Models.Enrollment>

@{
    ViewData["Title"] = "My Transcript";
    // Safely cast the ViewBag data to prevent errors if null
    double cumulativeGpa = ViewBag.GPA != null ? (double)ViewBag.GPA : 0.0;
    int totalCredits = ViewBag.TotalCredits != null ? (int)ViewBag.TotalCredits : 0;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<div class="container py-4">

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Transcript</li>
        </ol>
    </nav>

    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h2 class="fw-bold mb-1">
                <i class="bi bi-journal-check text-primary me-2"></i> Academic Transcript
            </h2>
            <p class="text-muted">Your complete academic history and performance.</p>
        </div>

        <div class="col-md-4">
            <div class="card bg-primary text-white shadow-sm border-0">
                <div class="card-body d-flex justify-content-between align-items-center p-3">
                    <div>
                        <div class="text-white-50 small text-uppercase fw-bold">Cumulative GPA</div>
                        <div class="display-6 fw-bold">@cumulativeGpa.ToString("0.00")</div>
                    </div>
                    <div class="text-end border-start border-white border-opacity-25 ps-3">
                        <div class="h4 mb-0">@totalCredits</div>
                        <div class="small text-white-50">Credits Earned</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3">Course</th>
                        <th class="text-center">Credits</th>
                        <th class="text-center">Score (0-100)</th>
                        <th class="text-end pe-4">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        // Parse score for color coding/status logic
                        int.TryParse(item.Grade, out int score);

                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@item.Course.Title</div>
                                <div class="small text-muted">
                                    Code: CS@(item.CourseId)
                                </div>
                            </td>

                            <td class="text-center">
                                <span class="badge bg-light text-secondary border">@item.Course.Credits</span>
                            </td>

                            <td class="text-center fw-bold">
                                @if (score >= 90)
                                {
                                    <span class="text-success">@item.Grade</span>
                                }
                                else if (score < 60)
                                {

                                    <span class="text-danger">@item.Grade</span>
                                }
                                else
                                {

                                    <span class="text-dark">@item.Grade</span>
                                }
                            </td>

                            <td class="text-end pe-4">
                                @if (score >= 60)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success px-3">Passed</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-3">Failed</span>
                                }
                            </td>
                        </tr>
                    }

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center p-5 text-muted">
                                <i class="bi bi-journal-x fs-1 d-block mb-3"></i>
                                No graded courses available yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>