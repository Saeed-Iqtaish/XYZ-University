@model XYZ_University.Models.Enrollment

@{
    ViewData["Title"] = "Grade Student";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">

                <div class="card-header bg-white border-bottom p-4">
                    <h3 class="fw-bold mb-0">Update Grade</h3>
                    <p class="text-muted small mb-0">
                        @Model.Course?.Title &mdash; @Model.Student?.FirstName @Model.Student?.LastName
                    </p>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <input type="hidden" asp-for="CourseId" />
                        <input type="hidden" asp-for="StudentId" />

                        <div class="mb-4 bg-light p-3 rounded border">
                            <label class="small text-uppercase fw-bold text-muted">Student</label>
                            <div class="fw-bold text-dark fs-5">@Model.Student?.FirstName @Model.Student?.LastName</div>
                            <div class="text-muted small">@Model.Student?.Email</div>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Grade" class="control-label fw-bold small text-uppercase mb-1">Final Grade</label>
                            <input asp-for="Grade" class="form-control form-control-lg" placeholder="e.g. A, B+, 95" />
                            <span asp-validation-for="Grade" class="text-danger"></span>
                            <div class="form-text text-muted">Enter a letter grade (A-F) or numeric score.</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary fw-bold py-2">Save Grade</button>
                            <a asp-action="Index" asp-route-courseId="@Model.CourseId" class="btn btn-light text-secondary border">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}