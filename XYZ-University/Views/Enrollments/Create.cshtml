@model XYZ_University.Models.Enrollment

@{
    ViewData["Title"] = "Enroll Student";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">

                <div class="card-header bg-white border-bottom p-4">
                    <h3 class="fw-bold mb-0">Enroll New Student</h3>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label asp-for="CourseId" class="control-label fw-bold small text-uppercase mb-1">Select Course</label>
                            <select asp-for="CourseId" class="form-select" asp-items="ViewBag.CourseId"></select>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="StudentId" class="control-label fw-bold small text-uppercase mb-1">Select Student</label>
                            <select asp-for="StudentId" class="form-select" asp-items="ViewBag.StudentId"></select>
                        </div>

                        <input type="hidden" asp-for="Grade" value="" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success fw-bold py-2">Enroll Student</button>
                            <a href="javascript:history.back()" class="btn btn-light text-secondary border">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}