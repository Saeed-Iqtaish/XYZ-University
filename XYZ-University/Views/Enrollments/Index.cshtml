@model IEnumerable<XYZ_University.Models.Enrollment>

@{
    ViewData["Title"] = ViewBag.CourseTitle ?? "Enrollments";
    int courseId = ViewBag.CourseId != null ? (int)ViewBag.CourseId : 0;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<div class="container py-4">

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Home</a></li>
            @if (courseId > 0)
            {
                <li class="breadcrumb-item"><a asp-controller="Courses" asp-action="MyCourses" class="text-decoration-none">My Courses</a></li>
                <li class="breadcrumb-item active" aria-current="page">@ViewBag.CourseCode</li>
            }
            else
            {
                <li class="breadcrumb-item active" aria-current="page">Enrollments</li>
            }
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center">
            <a asp-controller="Courses" asp-action="MyCourses" class="btn btn-outline-secondary me-3 shadow-sm px-3 rounded-pill">
                <i class="bi bi-arrow-left"></i> Back to Courses
            </a>

            <div>
                <h2 class="mb-0 fw-bold text-dark">
                    @if (courseId > 0)
                    {
                        <span>@ViewBag.CourseCode: @ViewBag.CourseTitle</span>
                    }
                    else
                    {
                        <span>All Enrollments</span>
                    }
                </h2>
                <small class="text-muted">Spring 2026 • @Model.Count() Students</small>
            </div>
        </div>

        <a asp-action="Create" asp-route-courseId="@courseId" class="btn btn-success shadow-sm fw-bold px-4">
            <i class="bi bi-person-plus-fill me-2"></i> Enroll Student
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3">Student ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Current Grade</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 text-secondary font-monospace">
                                ST-@(item.StudentId.Length > 4 ? item.StudentId.Substring(item.StudentId.Length - 4).ToUpper() : item.StudentId)
                            </td>

                            <td class="fw-bold text-dark">
                                @item.Student.FirstName @item.Student.LastName
                            </td>

                            <td class="text-muted">
                                @item.Student.Email
                            </td>

                            <td class="fw-bold">
                                @if (string.IsNullOrEmpty(item.Grade))
                                {
                                    <span class="text-muted">-</span>
                                }
                                else if (item.Grade.StartsWith("A") || item.Grade.StartsWith("9"))
                                {
                                    <span class="text-success">@item.Grade</span>
                                }
                                else
                                {
                                    <span class="text-primary">@item.Grade</span>
                                }
                            </td>

                            <td class="text-end pe-4">
                                <a asp-action="Edit"
                                   asp-route-courseId="@item.CourseId"
                                   asp-route-studentId="@item.StudentId"
                                   class="btn btn-sm btn-outline-success fw-bold px-3 me-2">
                                    <i class="bi bi-pencil-square me-1"></i> Grade
                                </a>
                                <a asp-action="Delete"
                                   asp-route-courseId="@item.CourseId"
                                   asp-route-studentId="@item.StudentId"
                                   class="btn btn-sm btn-outline-danger fw-bold px-3">
                                    <i class="bi bi-trash-fill me-1"></i> Remove
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="text-center p-5">
                    <p class="text-muted">No students enrolled in this course yet.</p>
                </div>
            }
        </div>
    </div>
</div>