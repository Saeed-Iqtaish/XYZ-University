@model XYZ_University.Models.Department

@{
    ViewData["Title"] = "Create Department";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">

                <div class="card-header bg-white border-bottom p-4">
                    <h3 class="fw-bold mb-0">Create Department</h3>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Name" class="control-label fw-bold small text-uppercase mb-1">Department Name</label>
                            <input asp-for="Name" class="form-control" placeholder="e.g. Computer Science" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Code" class="control-label fw-bold small text-uppercase mb-1">Department Code</label>
                            <input asp-for="Code" class="form-control" placeholder="e.g. CS" />
                            <span asp-validation-for="Code" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary fw-bold py-2">Create Department</button>
                            <a asp-action="Index" class="btn btn-light text-secondary border">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}