@using Microsoft.AspNetCore.Identity
@using XYZ_University.Models
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Dashboard";
    var currentUser = await UserManager.GetUserAsync(User);
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<style>
    /* Custom Styles for Dashboard Cards */
    .hover-card {
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: pointer;
    }

        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }

    .icon-circle {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }
</style>

@if (User.IsInRole("Admin"))
{
    /* ===========================
       ADMIN DASHBOARD
       =========================== */
    <div class="container py-4">

        <div class="card shadow-sm border-0 mb-4" style="border-left: 5px solid #dc3545 !important;">
            <div class="card-body p-4">
                <h2 class="fw-bold mb-2">Welcome, Administrator</h2>
                <p class="text-muted mb-0">Select an action below to manage the university system.</p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <a asp-controller="Admin" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 shadow-sm border-0 hover-card">
                        <div class="card-body d-flex align-items-center p-4">
                            <div class="icon-circle bg-primary bg-opacity-10 text-primary me-3">
                                <i class="bi bi-people-fill fs-4"></i>
                            </div>
                            <div>
                                <h5 class="card-title fw-bold text-dark mb-1">Manage Users</h5>
                                <small class="text-muted">Assign roles and offices.</small>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a asp-controller="Courses" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 shadow-sm border-0 hover-card">
                        <div class="card-body d-flex align-items-center p-4">
                            <div class="icon-circle bg-success bg-opacity-10 text-success me-3">
                                <i class="bi bi-journal-bookmark-fill fs-4"></i>
                            </div>
                            <div>
                                <h5 class="card-title fw-bold text-dark mb-1">Manage Courses</h5>
                                <small class="text-muted">Create courses and assign staff.</small>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a asp-controller="Departments" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 shadow-sm border-0 hover-card">
                        <div class="card-body d-flex align-items-center p-4">
                            <div class="icon-circle bg-secondary bg-opacity-10 text-secondary me-3">
                                <i class="bi bi-building-fill fs-4"></i>
                            </div>
                            <div>
                                <h5 class="card-title fw-bold text-dark mb-1">Departments</h5>
                                <small class="text-muted">Manage academic departments.</small>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a asp-controller="Offices" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 shadow-sm border-0 hover-card">
                        <div class="card-body d-flex align-items-center p-4">
                            <div class="icon-circle bg-warning bg-opacity-10 text-warning me-3">
                                <i class="bi bi-door-open-fill fs-4"></i>
                            </div>
                            <div>
                                <h5 class="card-title fw-bold text-dark mb-1">Offices</h5>
                                <small class="text-muted">Assign physical locations.</small>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>
}
else if (User.IsInRole("Instructor"))
{
    /* ===========================
       INSTRUCTOR DASHBOARD (MATCHING YOUR IMAGE)
       =========================== */
    <div class="container py-4">

        <div class="card shadow-sm border-0 mb-4" style="border-left: 5px solid #0d6efd !important;">
            <div class="card-body p-4">
                <h2 class="fw-bold mb-2">Welcome, @(currentUser?.FirstName != null ? $"{currentUser.FirstName} {currentUser.LastName}" : "Instructor")</h2>
                <p class="text-muted mb-0">Select an action below to manage the university system.</p>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                <a asp-controller="Courses" asp-action="MyCourses" class="text-decoration-none">
                    <div class="card h-100 shadow-sm border-0 hover-card">
                        <div class="card-body d-flex align-items-center p-4">
                            <div class="icon-circle bg-primary bg-opacity-10 text-primary me-3">
                                <i class="bi bi-easel-fill fs-4"></i>
                            </div>
                            <div>
                                <h5 class="card-title fw-bold text-dark mb-1">My Classes</h5>
                                <small class="text-muted">View roster and grade students.</small>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>
}
else if (User.IsInRole("Student"))
{
    /* ===========================
       STUDENT DASHBOARD (MATCHING YOUR IMAGE)
       =========================== */
    <div class="container py-4">

        <div class="card shadow-sm border-0 mb-4" style="border-left: 5px solid #198754 !important;">
            <div class="card-body p-4">
                <h2 class="fw-bold mb-2">Welcome, @(currentUser?.FirstName ?? "Student")</h2>
                <p class="text-muted mb-0">Select an action below to manage the university system.</p>
            </div>
        </div>

        <div class="row g-4">

            <div class="col-md-6">
                <a asp-controller="Enrollments" asp-action="MyGrades" class="text-decoration-none">
                    <div class="card h-100 shadow-sm border-0 hover-card">
                        <div class="card-body d-flex align-items-center p-4">
                            <div class="icon-circle bg-success bg-opacity-10 text-success me-3">
                                <i class="bi bi-file-earmark-text-fill fs-4"></i>
                            </div>
                            <div>
                                <h5 class="card-title fw-bold text-dark mb-1">My Grades</h5>
                                <small class="text-muted">View academic transcript.</small>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-6">
                <a asp-controller="Enrollments" asp-action="MySchedule" class="text-decoration-none">
                    <div class="card h-100 shadow-sm border-0 hover-card">
                        <div class="card-body d-flex align-items-center p-4">
                            <div class="icon-circle bg-info bg-opacity-10 text-info me-3">
                                <i class="bi bi-list-ul fs-4"></i>
                            </div>
                            <div>
                                <h5 class="card-title fw-bold text-dark mb-1">Course Catalog</h5>
                                <small class="text-muted">Browse available courses.</small>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

        </div>
    </div>
}
else
{
    /* ===========================
       PUBLIC / LOGGED OUT VIEW
       =========================== */
    <div class="text-center mt-5">
        <h1 class="display-4">Welcome to XYZ University</h1>
        <p class="lead">Please log in to manage your account.</p>
        <a class="btn btn-primary btn-lg" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </div>
}