@model IEnumerable<XYZ_University.Models.Office>

@{
    ViewData["Title"] = "Office Assignments";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<div class="container py-4">

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Office Management</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary me-3 shadow-sm">
                <i class="bi bi-arrow-left"></i> Dashboard
            </a>
            <h2 class="mb-0 fw-bold">
                <i class="bi bi-door-open-fill text-primary me-2"></i> Office Assignments
            </h2>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm fw-bold px-3">
            <i class="bi bi-plus-lg"></i> Assign Office
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3">Location</th>
                        <th>Assigned Instructor</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-dark">
                                @item.Location
                            </td>

                            <td>
                                @if (item.Instructor != null)
                                {
                                    <span class="text-dark">
                                        @item.Instructor.FirstName @item.Instructor.LastName
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Unassigned</span>
                                }
                            </td>

                            <td>
                                @if (item.Instructor != null)
                                {
                                    <span class="badge rounded-pill bg-success px-3 py-2 border border-light shadow-sm">
                                        Occupied
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-warning text-dark px-3 py-2 border border-light shadow-sm">
                                        Vacant
                                    </span>
                                }
                            </td>

                            <td class="text-end pe-4">
                                <a asp-action="Delete" asp-route-id="@item.OfficeId" class="text-danger me-3" title="Delete">
                                    <i class="bi bi-trash-fill fs-5"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.OfficeId" class="text-primary" title="Edit">
                                    <i class="bi bi-pencil-square fs-5"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>