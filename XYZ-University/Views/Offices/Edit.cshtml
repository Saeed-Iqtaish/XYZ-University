@model XYZ_University.Models.Office

@{
    ViewData["Title"] = "Edit Office";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">

                <div class="card-header bg-white border-bottom p-4">
                    <h3 class="fw-bold mb-0">Edit Office Assignment</h3>
                    <p class="text-muted small mb-0">Location: @Model.Location</p>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="OfficeId" />

                        <div class="form-group mb-3">
                            <label asp-for="Location" class="control-label fw-bold small text-uppercase mb-1">Office Location</label>
                            <input asp-for="Location" class="form-control" />
                            <span asp-validation-for="Location" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="InstructorId" class="control-label fw-bold small text-uppercase mb-1">Assigned Instructor</label>
                            <select asp-for="InstructorId" class="form-select" asp-items="ViewBag.InstructorId">
                                <option value="">-- Unassigned (Vacant) --</option>
                            </select>
                            <span asp-validation-for="InstructorId" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary fw-bold py-2">Save Changes</button>
                            <a asp-action="Index" class="btn btn-light text-secondary border">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}